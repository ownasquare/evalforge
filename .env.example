# Core runtime
EVALFORGE_ENVIRONMENT=development
EVALFORGE_APPLICATION_VERSION=0.3.0
EVALFORGE_DATABASE_URL=sqlite:///./.data/evalforge.db
EVALFORGE_SQLITE_BUSY_TIMEOUT_MS=5000
EVALFORGE_AUTO_MIGRATE=false
# Local mode only; shared workspaces must be provisioned deliberately.
EVALFORGE_SEED_DEMO=false
EVALFORGE_API_HOST=127.0.0.1
EVALFORGE_API_PORT=8000
EVALFORGE_API_URL=http://127.0.0.1:8000
EVALFORGE_DASHBOARD_HOST=127.0.0.1
EVALFORGE_DASHBOARD_PORT=8501
EVALFORGE_CORS_ORIGINS=["http://127.0.0.1:8501","http://localhost:8501"]
EVALFORGE_TRUSTED_HOSTS=["127.0.0.1","localhost","[::1]","testserver","api"]
EVALFORGE_LOG_LEVEL=INFO
EVALFORGE_JSON_LOGS=false
# Liveness/readiness stay public; /metrics requires this Bearer token when configured.
EVALFORGE_METRICS_BEARER_TOKEN=

# Identity. Local mode is zero-configuration and must remain loopback-only.
EVALFORGE_AUTH_MODE=local
EVALFORGE_OIDC_ISSUER=
EVALFORGE_OIDC_AUDIENCE=
EVALFORGE_OIDC_JWKS_URL=
EVALFORGE_PUBLIC_BASE_URL=
EVALFORGE_DASHBOARD_PUBLIC_BASE_URL=
EVALFORGE_OIDC_ALGORITHMS=["RS256","ES256"]
EVALFORGE_OIDC_CLOCK_SKEW_SECONDS=30
EVALFORGE_OIDC_JWKS_CACHE_SECONDS=3600
EVALFORGE_OIDC_JWKS_TIMEOUT_SECONDS=5
EVALFORGE_DASHBOARD_OIDC_PROVIDER=evalforge
# Compose-only host path to a non-committed Streamlit OAuth TOML file.
EVALFORGE_STREAMLIT_AUTH_SOURCE_FILE=
# Direct runtime path to a mounted Streamlit OAuth TOML file.
EVALFORGE_STREAMLIT_AUTH_FILE=
# Hosted fallback: the launcher writes these values to a temporary mode-0600 TOML file,
# removes them from the Streamlit process environment, and deletes the file on exit.
EVALFORGE_DASHBOARD_OIDC_CLIENT_ID=
EVALFORGE_DASHBOARD_OIDC_CLIENT_SECRET=
EVALFORGE_DASHBOARD_OIDC_SERVER_METADATA_URL=
EVALFORGE_DASHBOARD_OIDC_COOKIE_SECRET=

# Hosted commercialization pilot. Local/self-hosted mode remains unchanged when disabled.
EVALFORGE_COMMERCIAL_PILOT_ENABLED=false
EVALFORGE_HOSTED_TRIAL_DAYS=14
EVALFORGE_HOSTED_TRIAL_SEAT_LIMIT=5

# Execution safety
EVALFORGE_EXECUTOR_MODE=embedded_single
EVALFORGE_WORKER_POLL_INTERVAL_SECONDS=0.5
EVALFORGE_WORKER_LEASE_SECONDS=120
EVALFORGE_WORKER_HEARTBEAT_SECONDS=20
EVALFORGE_REAL_RUNS_ENABLED=false
EVALFORGE_MAX_CONCURRENT_GENERATIONS=4
EVALFORGE_MAX_CASES_PER_DATASET=500
EVALFORGE_MAX_VARIANTS_PER_RUN=12
EVALFORGE_MAX_CALLS_PER_RUN=1000
EVALFORGE_MAX_OUTPUT_TOKENS=2048
EVALFORGE_MAX_INPUT_CHARS_PER_CASE=20000
EVALFORGE_MAX_CONTEXT_CHARS_PER_CASE=100000
EVALFORGE_MAX_PROMPT_CHARS=50000
EVALFORGE_MAX_RENDERED_PROMPT_CHARS_PER_CALL=250000
EVALFORGE_MAX_ESTIMATED_INPUT_TOKENS_PER_RUN=2000000
EVALFORGE_INPUT_TOKEN_OVERHEAD_PER_REQUEST=128
EVALFORGE_MAX_ESTIMATED_COST_MICRO_USD_PER_RUN=10000000
EVALFORGE_PROVIDER_TIMEOUT_SECONDS=45

# Optional OpenAI Responses provider. Secrets remain backend-only.
EVALFORGE_OPENAI_API_KEY=
EVALFORGE_OPENAI_BASE_URL=https://api.openai.com/v1
EVALFORGE_OPENAI_MODEL_ALLOWLIST=["gpt-4.1-mini"]

# Optional OpenAI-compatible Chat Completions provider, including local gateways.
EVALFORGE_COMPATIBLE_API_KEY=
EVALFORGE_COMPATIBLE_AUTH_MODE=api_key
EVALFORGE_COMPATIBLE_BASE_URL=http://127.0.0.1:11434/v1
EVALFORGE_COMPATIBLE_MODEL_ALLOWLIST=[]
